# ─────────────────────────────────────────────────────────────────────────────
# Environment variables. ALL are optional — the app runs with none set.
# Copy to .env (local) or add them in Vercel → Project → Settings → Environment
# Variables. No exchange/trading API keys are ever required: market data is
# public and the app never places orders.
# ─────────────────────────────────────────────────────────────────────────────

# Telegram alerts (OPTIONAL). If both are unset, Telegram is simply disabled and
# the dashboard shows "Telegram: OFF". Used only by `npm run bot`; the deployed
# web app just reads whether they are present to show status.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Storage location (OPTIONAL). By default writes go to ./.data locally, or to
# /tmp/.data on Vercel (ephemeral). Point this at a mounted PERSISTENT volume
# (e.g. on a VM/Docker host) for durable runtime writes.
# DATA_DIR=/var/data/crypto-terminal

# Weekly scheduler hour, 0–23 local time (OPTIONAL, default 1). Used by
# `npm run schedule` only — not relevant on Vercel (serverless can't run a loop).
# SCHEDULE_HOUR=1
